NODE_ENV=development
PORT=3000

# Local dev default. In docker-compose, this is overridden to point at the
# `postgres` service hostname instead of localhost.
DATABASE_URL=postgres://dizzaract:changeme@localhost:5432/dizzaract

# Local dev default. In docker-compose, this is overridden to point at the
# `redis` service hostname instead of localhost.
REDIS_URL=redis://localhost:6379

# Dev-only placeholder - generate a real random secret for anything beyond
# local development, e.g. `openssl rand -hex 32`.
JWT_ACCESS_SECRET=dev-only-change-me-please-32chars

JWT_ACCESS_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# Used by docker-compose's postgres service and by DATABASE_URL above.
POSTGRES_USER=dizzaract
POSTGRES_PASSWORD=changeme
POSTGRES_DB=dizzaract
